POSTGRES_USER=DB_USER
POSTGRES_PASSWORD=DB_PASSWORD
POSTGRES_DB=DB_NAME

DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB_NAME

# Local Docker default — replace with your Upstash URL for production
# Format: rediss://default:<password>@<your-endpoint>.upstash.io:6379
REDIS_URL=redis://redis:6379/0

ENABLE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=HOST:9092

JWT_SECRET=YOUR_JWT_SECRET
