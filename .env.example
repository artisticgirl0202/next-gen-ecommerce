# backend/.env.example
# Copy this to backend/.env and fill with real secrets (DO NOT commit backend/.env)

# Database (SQLAlchemy style)
# Example: postgresql+psycopg2://<user>:<password>@<host>:5432/<db>
DATABASE_URL="postgresql+psycopg2://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>"

# If your docker-compose uses POSTGRES_* envs, include them as well:
POSTGRES_USER="<db_user>"
POSTGRES_PASSWORD="<db_password>"
POSTGRES_DB="<db_name>"

# Redis
REDIS_URL="redis://<host>:6379/0"

# Postgres connection string (DO NOT put real password here)
DATABASE_URL=postgresql+psycopg2://<DB_USER>:<DB_PASS>@<DB_HOST>:5432/<DB_NAME>

# Kafka
KAFKA_BOOTSTRAP_SERVERS="kafka:9092"   # or "host1:9092,host2:9092"
ENABLE_KAFKA="false"                  # "true"/"false" to enable startup of Kafka producer in dev

# JWT / auth
JWT_SECRET="<replace_with_random_secret>"    # HMAC secret for JWT signing

# External service API keys (placeholders only)
SENTRY_DSN=""
STRIPE_API_KEY=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# FAISS / model config (not secret but env-driven)
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
FAISS_INDEX_PATH="/data/faiss.index"

# App settings
ENV="development"   # production | staging | development
LOG_LEVEL="INFO"

# Optional: S3 / cloud storage credentials (if used)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
S3_BUCKET=""

# Toggle services
ENABLE_KAFKA=false

# Secret values - DO NOT PUT REAL VALUES HERE
JWT_SECRET=replace-with-your-jwt-secret
SENTRY_DSN=

# NOTE:
#  - Do NOT commit the real backend/.env. Keep backend/.env listed in .gitignore.
#  - Use your deployment platform's secret store (GitHub Secrets, Netlify env, etc.)
