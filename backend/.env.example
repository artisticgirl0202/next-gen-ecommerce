
#
# ── Local Docker (docker-compose 내부 postgres 서비스) ──
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@postgres:5432/DB_NAME
#
# ── Render Cloud DB ──
# DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxx.frankfurt-postgres.render.com/DB_NAME
#
# ── Neon Cloud DB (Pooler 주소 사용 권장) ──
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@ep-xxx-pooler.c-2.eu-central-1.aws.neon.tech/DB_NAME?sslmode=require&channel_binding=require
#
# ── 로컬 SQLite (DB 없이 빠른 테스트용) ──
# DATABASE_URL=sqlite:///./sql_app.db

# docker-compose postgres 서비스 자격증명 (로컬 전용)
POSTGRES_USER=DB_USER
POSTGRES_PASSWORD=DB_PASSWORD
POSTGRES_DB=DB_NAME


# =====================================================
# Redis
# =====================================================
# docker-compose 내부: redis://redis:6379/0
# 외부 Redis (Upstash 등): rediss://USER:PASSWORD@HOST:PORT
REDIS_URL=redis://redis:6379/0


# =====================================================
# Kafka (optional)
# =====================================================
# 사용 안 함: ENABLE_KAFKA=false (기본값)
# docker-compose 내부: kafka:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
ENABLE_KAFKA=false


# =====================================================
# Authentication / Security
# =====================================================
# 운영 환경에서는 반드시 충분히 긴 랜덤 문자열 사용
JWT_SECRET=YOUR_LONG_RANDOM_JWT_SECRET


# =====================================================
# CORS (배포 시 반드시 설정)
# =====================================================
# 쉼표로 구분, 슬래시 없이
# 예: https://your-app.vercel.app,http://localhost:5173
FRONT_ORIGINS=http://localhost:5173,http://localhost:4173

# Vercel preview 배포 URL을 정규표현식으로 허용 (선택)
# 예: https://next-gen-ecommerce.*-artisticgirls-projects\.vercel\.app
# 비워두면 비활성화됨
VERCEL_ORIGIN_REGEX=


# =====================================================
# App Settings
# =====================================================
# "development" → Swagger 활성화, /api/seed 허용, secure=False cookie
# "production"  → Swagger 비활성화, /api/seed 차단, secure=True cookie
ENVIRONMENT=development
LOG_LEVEL=INFO

# /api/seed 엔드포인트를 개발 환경에서도 비밀번호로 보호 (선택)
# 설정 시 요청 헤더 X-Seed-Secret 값과 일치해야 실행됨
# 비워두면 개발 환경에서는 인증 없이 접근 가능
SEED_SECRET=


# =====================================================
# ML / Search
# =====================================================
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
FAISS_INDEX_PATH=/data/faiss.index


# =====================================================
# External Services (optional)
# =====================================================
SENTRY_DSN=
STRIPE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
