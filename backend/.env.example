# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  backend/.env.example                                                   ║
# ║  이 파일을 backend/.env 로 복사한 뒤 실제 값으로 채우세요.                 ║
# ║  backend/.env 는 절대 Git 에 커밋하지 마세요. (.gitignore 에 포함됨)       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────────────
# [중요] 환경변수 우선순위 (높은 순)
#
#   1. 플랫폼 대시보드 주입값 (Render / Vercel / AWS 등)   ← 항상 최우선
#   2. Docker Compose env_file (backend/.env)              ← 로컬 개발용
#   3. 코드 내 기본값 (fallback: SQLite)
#
# 배포 시 .env 파일을 수정하거나 Git 에 올릴 필요가 없습니다.
# Render 대시보드 → Environment 탭에서 아래 키들을 직접 입력하세요.
# ──────────────────────────────────────────────────────────────────────────


# =====================================================
# Database  ★ 가장 중요 ★
# =====================================================
#
# 반드시 키 이름을 "DATABASE_URL" 로 사용해야 합니다.
# (DB_URL, POSTGRES_URL 등 다른 이름은 코드가 인식하지 못합니다.)
#
# ── Local Docker (docker-compose 내부 postgres 서비스) ──
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@postgres:5432/DB_NAME
#
# ── Render Cloud DB ──
# DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxx.frankfurt-postgres.render.com/DB_NAME
#
# ── Neon Cloud DB (Pooler 주소 사용 권장) ──
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@ep-xxx-pooler.c-2.eu-central-1.aws.neon.tech/DB_NAME?sslmode=require&channel_binding=require
#
# ── 로컬 SQLite (DB 없이 빠른 테스트용) ──
# DATABASE_URL=sqlite:///./sql_app.db

# docker-compose postgres 서비스 자격증명 (로컬 전용)
POSTGRES_USER=DB_USER
POSTGRES_PASSWORD=DB_PASSWORD
POSTGRES_DB=DB_NAME


# =====================================================
# Redis
# =====================================================
# docker-compose 내부: redis://redis:6379/0
# 외부 Redis (Upstash 등): rediss://USER:PASSWORD@HOST:PORT
REDIS_URL=redis://redis:6379/0


# =====================================================
# Kafka (optional)
# =====================================================
# 사용 안 함: ENABLE_KAFKA=false (기본값)
# docker-compose 내부: kafka:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
ENABLE_KAFKA=false


# =====================================================
# Authentication / Security
# =====================================================
# 운영 환경에서는 반드시 충분히 긴 랜덤 문자열 사용
JWT_SECRET=YOUR_LONG_RANDOM_JWT_SECRET


# =====================================================
# CORS (배포 시 반드시 설정)
# =====================================================
# 쉼표로 구분, 슬래시 없이
# 예: https://your-app.vercel.app,http://localhost:5173
FRONT_ORIGINS=http://localhost:5173,http://localhost:4173


# =====================================================
# App Settings
# =====================================================
ENV=development
LOG_LEVEL=INFO


# =====================================================
# ML / Search
# =====================================================
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
FAISS_INDEX_PATH=/data/faiss.index


# =====================================================
# External Services (optional)
# =====================================================
SENTRY_DSN=
STRIPE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
