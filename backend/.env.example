
# backend/.env.example
# Copy this file to backend/.env and fill in real values.
# DO NOT commit backend/.env

# =====================================================
# Database
# =====================================================
# SQLAlchemy connection string
# Format:
# postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB_NAME

# If using docker-compose with Postgres
POSTGRES_USER=DB_USER
POSTGRES_PASSWORD=DB_PASSWORD
POSTGRES_DB=DB_NAME

# =====================================================
# Redis
# =====================================================
# Format: redis://HOST:PORT/DB_INDEX
REDIS_URL=redis://HOST:6379/0

# =====================================================
# Kafka (optional)
# =====================================================
KAFKA_BOOTSTRAP_SERVERS=HOST:9092
ENABLE_KAFKA=false

# =====================================================
# Authentication / Security
# =====================================================
# JWT HMAC secret (use a long random string in real env)
JWT_SECRET=YOUR_JWT_SECRET

# =====================================================
# External Services (optional)
# =====================================================
SENTRY_DSN=
STRIPE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# =====================================================
# ML / Search
# =====================================================
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
FAISS_INDEX_PATH=/data/faiss.index

# =====================================================
# App Settings
# =====================================================
ENV=development          # development | staging | production
LOG_LEVEL=INFO

# =====================================================
# Cloud Storage (optional)
# =====================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
